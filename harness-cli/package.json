{
  "name": "@harness-lab/cli",
  "version": "0.7.0",
  "description": "Participant-facing Harness Lab CLI for facilitator auth and workshop operations",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ondrej-svec/harness-lab.git",
