{
  "name": "harness-lab-dashboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "prebuild": "node scripts/copy-agenda-source.mjs",
    "predev": "node scripts/copy-agenda-source.mjs",
    "pretest": "node scripts/copy-agenda-source.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:neon": "playwright test --config=playwright.neon.config.ts",
    "test:integration": "vitest run --reporter=verbose 'lib/**/*.integration.test.ts'",
    "db:migrate": "node scripts/run-migrations.mjs",
    "generate:briefs": "bun ../scripts/content/generate-briefs-inventory.ts",
    "generate:content": "bun ../scripts/content/generate-briefs-inventory.ts && bun ../scripts/content/generate-views.ts",
    "verify:content": "bun ../scripts/content/generate-briefs-inventory.ts --verify && bun ../scripts/content/generate-views.ts --verify && bun ../scripts/content/check-tier2-sync.ts && bun ../scripts/content/verify-copy-editor.ts",
    "verify:copy-editor": "bun ../scripts/content/verify-copy-editor.ts"
  },
  "dependencies": {
    "@neondatabase/auth": "^0.2.0-beta.1",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.3.3",
    "botid": "^1.5.11",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "set-cookie-parser": "^3.1.0",
    "zod": "^4.4.1"
  },
  "pnpm": {
    "overrides": {
      "better-auth": ">=1.6.2"
    }
  },
  "overrides": {
    "better-auth": ">=1.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
