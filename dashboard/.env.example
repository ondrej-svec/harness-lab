HARNESS_STORAGE_MODE=file
HARNESS_WORKSHOP_INSTANCE_ID=sample-studio-a

# Switch to neon for private runtime storage.
# HARNESS_STORAGE_MODE=neon
# HARNESS_DATABASE_URL=postgres://user:password@host/dbname

# Optional preview-grade integration database used by GitHub Actions.
# HARNESS_TEST_DATABASE_URL=postgres://user:password@host/dbname

# Demo-only facilitator basic-auth challenge for /admin.
HARNESS_ADMIN_USERNAME=facilitator
HARNESS_ADMIN_PASSWORD=secret

# Optional demo seed for participant event access.
HARNESS_EVENT_CODE=lantern8-context4-handoff2
# HARNESS_EVENT_CODE_EXPIRES_AT=2026-04-20T12:00:00.000Z

# Server-side HMAC key used to hash participant event codes. Required in
# production and whenever HARNESS_STORAGE_MODE=neon. Must be at least 32
# characters. Generate with: openssl rand -base64 48
# HARNESS_EVENT_CODE_SECRET=replace-with-a-32-plus-char-random-key

# Optional public repo links for homepage, participant CTAs, and source refs.
# NEXT_PUBLIC_HARNESS_REPO_URL=https://github.com/<your-account>/harness-lab
# NEXT_PUBLIC_HARNESS_REPO_BRANCH=main

# For deployment-grade env scoping, see:
# ../docs/private-workshop-instance-env-matrix.md
