HARNESS_STORAGE_MODE=file

# Switch to neon for private runtime storage.
# HARNESS_STORAGE_MODE=neon
# HARNESS_DATABASE_URL=postgres://user:password@host/dbname

# Throwaway Neon branch used by integration + Playwright runs that need
# real Neon Auth. Never run those layers against main — production
# participant rows must not be touched by automated tests.
#
# Spin up a per-run branch:
#   node dashboard/scripts/create-test-branch.mjs
#
# The script writes the pooled connection URI into
# dashboard/.env.test.local (gitignored) under HARNESS_TEST_DATABASE_URL,
# along with HARNESS_TEST_BRANCH_NAME / HARNESS_TEST_BRANCH_ID. Tear
# down with:
#   node dashboard/scripts/delete-test-branch.mjs
#
# Set HARNESS_NEON_PROJECT_ID to the Neon project you want the test
# branch scripts to use. Find the project ID in the Neon Console at
# https://console.neon.tech/app/projects — it looks like
# "broad-smoke-12345678". There is no default; the scripts throw if
# the env var is absent.
# HARNESS_TEST_DATABASE_URL=postgres://user:password@host/dbname

# Demo-only facilitator basic-auth challenge for /admin.
HARNESS_ADMIN_USERNAME=facilitator
HARNESS_ADMIN_PASSWORD=secret

# Optional demo seed for participant event access.
HARNESS_EVENT_CODE=lantern8-context4-handoff2
# HARNESS_EVENT_CODE_EXPIRES_AT=2026-04-20T12:00:00.000Z

# Server-side HMAC key used to hash participant event codes. Required in
# production and whenever HARNESS_STORAGE_MODE=neon. Must be at least 32
# characters. Generate with: openssl rand -base64 48
# HARNESS_EVENT_CODE_SECRET=replace-with-a-32-plus-char-random-key

# Neon control-plane API key + project / branch identifiers used by
# lib/auth/admin-create-user.ts to mint participant Neon Auth users
# without enabling public signup. Required in Neon mode (production
# and Playwright Neon-mode suite). Manage the key in the Neon Console
# at https://console.neon.tech/app/settings/api-keys — never commit.
# The branch id defaults to the project's primary branch in production;
# Playwright runs use the throwaway branch id from .env.test.local.
# NEON_API_KEY=napi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HARNESS_NEON_PROJECT_ID=your-neon-project-id
# HARNESS_NEON_BRANCH_ID=your-neon-branch-id

# Optional public repo links for homepage, participant CTAs, and source refs.
# NEXT_PUBLIC_HARNESS_REPO_URL=https://github.com/<your-account>/harness-lab
# NEXT_PUBLIC_HARNESS_REPO_BRANCH=main

# Vercel Blob read/write token. Required for cohort-specific artifact
# uploads (`harness workshop artifact upload ...`) and for the
# authenticated serve route at `/participant/artifact/[id]`.
# Pull locally with `vercel env pull dashboard/.env.vercel.local`.
# In file mode (HARNESS_STORAGE_MODE=file), uploads are written to
# HARNESS_DATA_DIR instead and this token is not required.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cap on artifact upload size in bytes. Defaults to 25 MiB. Values
# above this are rejected by the upload API with a 413.
# ARTIFACT_MAX_BYTES=26214400

# For deployment-grade env scoping, see:
# ../docs/private-workshop-instance-env-matrix.md
